# Dockerfile.therock
# Builds llama.cpp with HIP/TheRock targeting gfx1151.
# Base: kyuz0/vllm-therock-gfx1151:20251130-175119 (Fedora 43)

FROM docker.io/kyuz0/vllm-therock-gfx1151:20251130-175119

ENV PATH="/opt/venv/bin:${PATH}"
ENV HIP_PLATFORM=amd

# Register ROCm lib dirs with the dynamic linker
RUN ROCM_SDK=$(find /opt/venv -maxdepth 5 -name '_rocm_sdk_core' -type d 2>/dev/null | head -1) \
    && echo '/opt/rocm/lib' > /etc/ld.so.conf.d/rocm.conf \
    && echo "${ROCM_SDK}/lib" >> /etc/ld.so.conf.d/rocm.conf \
    && ldconfig

RUN git clone --depth 1 https://github.com/ggml-org/llama.cpp /opt/llama.cpp

# Patch: disable UMA/APU detection in ggml-cuda.
# ggml uses hipDeviceAttributeIntegrated to detect APU/UMA and then allocates
# KV cache via hsa_amd_memory_pool_allocate (fine-grained memory). On gfx1151
# with libhsa-runtime64.so.1.18.0 this segfaults at offset 0xac2de.
# Replacing with hipDeviceAttributeEccEnabled (always 0 on consumer GPUs)
# makes ggml treat the device as non-UMA and use plain hipMalloc instead.
RUN grep -rl 'hipDeviceAttributeIntegrated' /opt/llama.cpp/ggml/src/ \
    | xargs sed -i 's/hipDeviceAttributeIntegrated/hipDeviceAttributeEccEnabled/g' \
    && echo 'Patched files:' \
    && grep -rl 'hipDeviceAttributeEccEnabled' /opt/llama.cpp/ggml/src/

RUN cd /opt/llama.cpp && \
    cmake -B build -G Ninja \
      -DCMAKE_BUILD_TYPE=Release \
      -DGGML_HIP=ON \
      -DGGML_HIPBLAS=OFF \
      -DAMDGPU_TARGETS="gfx1151" \
      -DCMAKE_HIP_ARCHITECTURES="gfx1151" \
      -DCMAKE_C_COMPILER=gcc \
      -DCMAKE_CXX_COMPILER=g++ \
      -DCMAKE_PREFIX_PATH=/opt/rocm \
    && cmake --build build -j$(nproc) \
    && cmake --install build --prefix /usr \
    && ldconfig \
    && rm -rf /opt/llama.cpp/build

EXPOSE 8000
