# AMD documents a vLLM Docker path for gfx1151/gfx1150 support.
# Override this if you want a different image/tag.
VLLM_BASE_IMAGE=docker.io/kyuz0/vllm-therock-gfx1151:latest
#VLLM_BASE_IMAGE=rocm/vllm-dev:rocm7.2.1_navi_ubuntu24.04_py3.12_pytorch_2.9_vllm_0.16.0
LOCAL_IMAGE=strix-vllm-mistral:local
COMPOSE_IMAGE_NAME=strix-vllm:local
CONTAINER_NAME=strix-vllm

# Quantized smart model + Eagle draft model.
VLLM_SMART_MODEL=cyankiwi/Mistral-Small-4-119B-2603-AWQ-4bit
VLLM_DRAFT_MODEL=mistralai/Mistral-Small-4-119B-2603-eagle
VLLM_QUANTIZATION=awq

# Start conservative for 90 GB of mapped GPU memory.
SERVER_PORT=8000
VLLM_MAX_MODEL_LEN=8192
VLLM_SPEC_MAX_MODEL_LEN=8192
VLLM_NUM_SPECULATIVE_TOKENS=3
VLLM_MAX_NUM_BATCHED_TOKENS=8192
VLLM_MAX_NUM_SEQS=16
VLLM_GPU_MEMORY_UTILIZATION=0.88
VLLM_ATTENTION_BACKEND=FLASH_ATTN_MLA

# ROCm / runtime knobs.
HSA_XNACK=1
HSA_ENABLE_SDMA=0
ROCR_VISIBLE_DEVICES=0
VLLM_USE_V1=0
VLLM_LOGGING_LEVEL=INFO
PYTORCH_TUNABLEOP_ENABLED=1
PYTORCH_TUNABLEOP_TUNING=0

# Persistent caches / model storage on the host.
HF_CACHE_DIR=/mnt/data/hf-cache
VLLM_CACHE_DIR=/mnt/data/vllm-cache
MODEL_DIR=/mnt/data/models/vllm
