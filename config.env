# =============================================================================
# Strix Halo — llama.cpp (Vulkan RADV) configuration
# =============================================================================

# Docker image tag for kyuz0's toolbox
# Some models perform faster on one or the other; test both and set this to the best for your use case.
LLAMA_IMAGE_TAG=vulkan-radv
###LLAMA_IMAGE_TAG=vulkan-amdvlk
###LLAMA_IMAGE_TAG=rocm-6.4.4-rocwmma

# ── Paths ─────────────────────────────────────────────────────────────────────
# Primary models directory (HF safetensors, GGUFs, etc.)
MODELS_DIR=/mnt/data/models

# llama-server download + HF cache (persistent across container restarts)
HOST_LLAMA_CACHE=/mnt/data/llama.cpp-cache

# Extra model search directories (colon-separated)
# lib.sh already searches the most common locations automatically.
# Add unusual paths here — e.g. a second drive or a shared NAS mount.
EXTRA_MODEL_SEARCH_DIRS=

# ── Server defaults ───────────────────────────────────────────────────────────
SERVER_PORT=8000

# ── Default model (used by start.sh on boot) ──────────────────────────────────

### Mistral Small 4 (GGUF) — a compact, efficient LLaMA 3.1 variant with 4-bit quantization, ideal for general-purpose use ###
DEFAULT_LOADER=load_mistral-small-4_q4.sh
MODEL_HF_ID=unsloth/Mistral-Small-4-119B-2603-GGUF
MODEL_KEYWORD=mistral-small-4
MODEL_ALIAS=mistral-small-4
PREF_QUANT=UD-Q4_K_M

## TODO: Defined speculative decoder
# vllm serve mistralai/Mistral-Small-4-119B-2603 \
#   --speculative_config '{
#     "model": "mistralai/Mistral-Small-4-119B-2603-eagle",
#     "num_speculative_tokens": 3,
#     "method": "eagle",
#     "max_model_len": "16384"
#   }'

# ── llama-server tuning ───────────────────────────────────────────────────────
#LLAMA_CTX_SIZE=8192 
LLAMA_NGL=999       # number of layers on GPU (999 = all)
LLAMA_THREADS=1     # CPU threads — Strix Halo has 16c/32t, 16 is a good start
LLAMA_TEMP=0.2
LLAMA_TOP_P=0.95

# ── Model search — overrides (optional) ──────────────────────────────────────
# These are set at runtime by load_*.sh scripts; leave blank here.
MODEL_FLAG=
MODEL_VALUE=
